Bootstrap: docker
From: registry.fedoraproject.org/fedora-minimal:40

%labels
    Author gaccordi
    Purpose Portable development image with OS tooling, /opt/spack, and mounted state

%help
    Portable Apptainer base image.

    Build:
      apptainer build --fakeroot images/base.sif defs/base.def

    Run:
      apptainer run images/base.sif
      apptainer run --home "$HOME:/home/$USER" \
        --bind "$PWD/mounts/fedora:/mnt/dev" \
        --env APPTAINER_DEV_MOUNT=/mnt/dev \
        --env APPTAINER_DEV_STATE_DIR=/mnt/dev/spack \
        images/base.sif
      apptainer run --home "$HOME:/home/$USER" \
        --bind "$PWD/.apptainer-spack:/home/$USER/.apptainer-spack" \
        --env APPTAINER_DEV_STATE_DIR=/home/$USER/.apptainer-spack \
        images/base.sif

    Notes:
      - This image bakes in OS/editor/build dependencies and /opt/spack.
      - Spack installs, environments, cache, and Tcl modulefiles live in the
        mounted writable state directory.
      - Run dev-bootstrap-spack-state once inside the container, or use the
        host wrapper bin/base-bootstrap-spack.sh.
      - Tcl modulefiles are generated automatically into the mounted state.
      - The image already includes /etc/profile.d/90-apptainer-dev-base.sh, so
        host runtime wrappers do not need to bind in a profile script.
      - You do not need fakeroot for runtime spack install. fakeroot is only
        needed to build the image itself.
      - The image also includes Codex (`codex`), Copilot CLI (`copilot`),
        Continue CLI (`cn`), and Claude Code (`claude`).

%files
    support/90-apptainer-dev-base.sh /etc/profile.d/90-apptainer-dev-base.sh
    support/dev-bootstrap-spack-state /usr/local/bin/dev-bootstrap-spack-state
    support/dev-shell /usr/local/bin/dev-shell
    support/90-apptainer-dev-base.fish /etc/fish/conf.d/90-apptainer-dev-base.fish

%environment
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export EDITOR=nvim

%post
    set -euo pipefail

    if command -v dnf >/dev/null 2>&1; then
        PM=dnf
    else
        PM=microdnf
    fi

    "$PM" install -y --setopt=install_weak_deps=0 \
        git \
        automake \
        ncurses ncurses-term \
        wget \
        python3 \
        python3-pygments \
        python3-pip \
        python3-rpm \
        zsh \
	      fish \
        fastfetch \
        eza \
        tmux \
        vim-enhanced \
        kitty \
        ImageMagick \
        bubblewrap \
        curl \
        ripgrep \
        fd-find \
        fzf \
        golang \
        jq \
        tree-sitter-cli \
        luarocks \
        wl-clipboard \
        xclip \
        xsel \
        btop \
        nvtop \
        cmake \
        cargo \
        gdb \
        gcc \
        gcc-c++ \
        clang libomp libomp-devel \
        gcc-gfortran \
        make \
        rust \
        shfmt \
        patch \
        valgrind \
        diffutils \
        findutils \
        file \
        tar \
        gzip \
        bzip2 \
        xz \
        lbzip2 \
        unzip \
        environment-modules
    "$PM" clean all || true

    NODE_BASE_URL="https://nodejs.org/download/release/latest-v22.x"
    NODE_TARBALL="$(curl -fsSL "${NODE_BASE_URL}/SHASUMS256.txt" | awk '/linux-x64.tar.xz$/ { print $2; exit }')"
    NODE_SHA256="$(curl -fsSL "${NODE_BASE_URL}/SHASUMS256.txt" | awk -v tarball="$NODE_TARBALL" '$2 == tarball { print $1; exit }')"
    curl -fsSL -o "/tmp/${NODE_TARBALL}" "${NODE_BASE_URL}/${NODE_TARBALL}"
    printf '%s  %s\n' "${NODE_SHA256}" "/tmp/${NODE_TARBALL}" | sha256sum -c -
    rm -rf /usr/local/lib/node_modules /usr/local/include/node /usr/local/bin/node /usr/local/bin/npm /usr/local/bin/npx
    tar -C /usr/local --strip-components=1 -xJf "/tmp/${NODE_TARBALL}"
    rm -f "/tmp/${NODE_TARBALL}"

    npm install -g \
        @openai/codex \
        @github/copilot \
        @continuedev/cli \
        @google/gemini-cli \
        @anthropic-ai/claude-code
    npm cache clean --force || true

    python3 -m pip install --no-cache-dir --prefix /usr/local \
        pynvim \
        black \
        ruff

    LAZYGIT_VERSION="0.61.1"
    LAZYGIT_TARBALL="lazygit_${LAZYGIT_VERSION}_linux_x86_64.tar.gz"
    LAZYGIT_CHECKSUMS_URL="https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/checksums.txt"
    LAZYGIT_SHA256="$(curl -fsSL "${LAZYGIT_CHECKSUMS_URL}" | awk -v tarball="${LAZYGIT_TARBALL}" '$2 == tarball { print $1; exit }')"
    curl -fsSL -o "/tmp/${LAZYGIT_TARBALL}" \
        "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/${LAZYGIT_TARBALL}"
    printf '%s  %s\n' "${LAZYGIT_SHA256}" "/tmp/${LAZYGIT_TARBALL}" | sha256sum -c -
    tar -C /usr/local/bin -xzf "/tmp/${LAZYGIT_TARBALL}" lazygit
    chmod 0755 /usr/local/bin/lazygit
    rm -f "/tmp/${LAZYGIT_TARBALL}"

    NVIM_VERSION="0.12.1"
    curl -fsSL \
        -o /tmp/nvim-linux-x86_64.tar.gz \
        "https://github.com/neovim/neovim/releases/download/v${NVIM_VERSION}/nvim-linux-x86_64.tar.gz"
    rm -rf /opt/nvim-linux-x86_64
    mkdir -p /opt /workspace
    tar -C /opt -xzf /tmp/nvim-linux-x86_64.tar.gz
    ln -sf /opt/nvim-linux-x86_64/bin/nvim /usr/local/bin/nvim
    rm -f /tmp/nvim-linux-x86_64.tar.gz

    SPACK_IMAGE_REF="develop"
    rm -rf /opt/spack
    git clone --depth 1 --branch "${SPACK_IMAGE_REF}" https://github.com/spack/spack.git /opt/spack
    chmod -R a+rX /opt/spack

    chmod 0644 /etc/profile.d/90-apptainer-dev-base.sh
    chmod 0755 /usr/local/bin/dev-bootstrap-spack-state /usr/local/bin/dev-shell

    if [ -f /etc/zshrc ]; then
        if ! grep -q '90-apptainer-dev-base.sh' /etc/zshrc; then
            cat >>/etc/zshrc <<'ZSHRC'
[[ -f /etc/profile.d/90-apptainer-dev-base.sh ]] && source /etc/profile.d/90-apptainer-dev-base.sh
ZSHRC
        fi
    elif [ -d /etc/zsh ]; then
        cat >/etc/zsh/zshrc <<'ZSHRC'
[[ -f /etc/profile.d/90-apptainer-dev-base.sh ]] && source /etc/profile.d/90-apptainer-dev-base.sh
ZSHRC
    else
        cat >/etc/zshrc <<'ZSHRC'
[[ -f /etc/profile.d/90-apptainer-dev-base.sh ]] && source /etc/profile.d/90-apptainer-dev-base.sh
ZSHRC
    fi

%runscript
    exec /usr/local/bin/dev-shell "$@"

%test
    set -e
    command -v zsh >/dev/null
    command -v tmux >/dev/null
    command -v vim >/dev/null
    command -v nvim >/dev/null
    command -v btop >/dev/null
    command -v nvtop >/dev/null
    command -v module >/dev/null
    command -v dev-bootstrap-spack-state >/dev/null
    test -f /opt/spack/share/spack/setup-env.sh
